#================================================
# THEMES
#================================================
# Ignore all themes
/themes/*

# Allow project theme
!/themes/sello_angelical


#================================================
# PLUGINS
#================================================
# Ignore all plugins
/plugins/*

# Allow project plugins (prefix ki-)
!/plugins/sa-*/


#================================================
# UPLOADS (media files)
#================================================
/uploads/


#================================================
# WORDPRESS TEMP FILES
#================================================
/upgrade/
cache/
backups/


#================================================
# DEPENDENCIES
#================================================
node_modules/
vendor/


#================================================
# LOGS
#================================================
*.log
debug.log


#================================================
# ENVIRONMENT FILES
#================================================
.env
.env.*


#================================================
# BUILD FILES
#================================================
dist/
build/
*.map


#================================================
# OS FILES
#================================================
.DS_Store
.Trashes
Thumbs.db


#================================================
# IDE FILES
#================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace


#================================================
# WORDPRESS SECURITY / PLUGINS
#================================================
/wflogs/
.logs/


#================================================
# LARGE FILES (should not be in git)
#================================================
*.zip
*.tar
*.gz
*.rar
*.mp4
*.mov
*.avi
*.mp3
*.wav
*.psd
*.ai
*.sketch
